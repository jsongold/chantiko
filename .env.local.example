# Pulled from Vercel via `vercel env pull .env.local`
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Add manually
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=

# Dev mode (set to true to skip auth)
NEXT_PUBLIC_AUTH_DISABLED=false
AUTH_DISABLED=false

# Feature flags (default: all enabled, set to "false" to disable)
NEXT_PUBLIC_FEATURE_PROGRESS=true
NEXT_PUBLIC_FEATURE_AI_EDIT=true
NEXT_PUBLIC_FEATURE_GOALS=true
